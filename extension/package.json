{
  "name": "testcasepilot",
  "displayName": "TestCasePilot",
  "description": "Generate review-ready QA test cases from a requirement using the TestCasePilot backend.",
  "version": "0.1.0",
  "publisher": "testcasepilot",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "testcasePilot.analyzeRequirement",
        "title": "TestCasePilot: Analyze Requirement"
      },
      {
        "command": "testcasePilot.generate",
        "title": "TestCasePilot: Generate Test Cases"
      },
      {
        "command": "testcasePilot.openSidebar",
        "title": "TestCasePilot: Open Sidebar"
      },
      {
        "command": "testcasePilot.checkBackendStatus",
        "title": "TestCasePilot: Check Backend Status"
      },
      {
        "command": "testcasePilot.newRequirement",
        "title": "TestCasePilot: New Requirement (Form)",
        "icon": "$(beaker)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "testcasePilot.newRequirement",
          "group": "navigation",
          "when": "resourceLangId == markdown"
        }
      ],
      "editor/context": [
        {
          "command": "testcasePilot.generate",
          "group": "testcasePilot",
          "when": "editorLangId == markdown || editorLangId == plaintext"
        },
        {
          "command": "testcasePilot.analyzeRequirement",
          "group": "testcasePilot",
          "when": "editorLangId == markdown || editorLangId == plaintext"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "testcasePilot",
          "title": "TestCasePilot",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "testcasePilot": [
        {
          "id": "testcasePilot.sidebar",
          "name": "TestCasePilot",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "TestCasePilot",
      "properties": {
        "testcasePilot.apiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Base URL of the TestCasePilot backend API."
        },
        "testcasePilot.defaultProvider": {
          "type": "string",
          "enum": ["auto", "openai", "claude", "ollama"],
          "default": "auto",
          "description": "Preferred AI provider hint forwarded to the backend. 'auto' lets the backend decide. The extension never calls a provider directly."
        },
        "testcasePilot.autoAnalyze": {
          "type": "boolean",
          "default": false,
          "description": "Automatically analyze a requirement file when it is saved."
        },
        "testcasePilot.enableLogs": {
          "type": "boolean",
          "default": true,
          "description": "Write API requests, errors, and timings to the 'TestCasePilot Output' channel."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "compile-tests": "tsc -p ./",
    "pretest": "npm run compile-tests",
    "test": "node --test out/test/*.test.js",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.4.0"
  }
}
